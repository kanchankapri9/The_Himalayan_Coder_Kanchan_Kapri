# FestFello Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ===========================
# SERVER CONFIG
# ===========================

# Port the backend server listens on
# Default: 5000
PORT=5000

# Node environment (development or production)
NODE_ENV=development

# ===========================
# DATABASE CONFIG
# ===========================

# MongoDB connection string
# Format: mongodb://username:password@host:port/database
# Example for local: mongodb://localhost:27017/festivities
# Example for Atlas: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/festivities

# ===========================
# JWT AUTH CONFIG
# ===========================

# Secret key for signing JWT tokens
# Use a strong random string (at least 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_at_least_32_characters_long

# JWT expiration time (optional, default is 7d)
# Format: number + time unit (d, h, m, s)
# Examples: 7d, 24h, 1440m
JWT_EXPIRE=7d

# ===========================
# CLOUDINARY CONFIG (Image Upload)
# ===========================

# Cloudinary cloud name
# Get from: https://cloudinary.com/console/settings/general
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# Cloudinary API key
# Get from: https://cloudinary.com/console/settings/api-keys
CLOUDINARY_API_KEY=your_cloudinary_api_key

# Cloudinary API secret
# Get from: https://cloudinary.com/console/settings/api-keys
# Keep this secret, never commit to git
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===========================
# OPTIONAL: PAYMENT GATEWAY CONFIG
# ===========================

# Razorpay API key (when payment integration is added)
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Stripe API key (when payment integration is added)
# STRIPE_SECRET_KEY=your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# ===========================
# OPTIONAL: EMAIL CONFIG
# ===========================

# SMTP service for sending emails (when email notifications are added)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password
# EMAIL_FROM=noreply@festivities.com

# ===========================
# OPTIONAL: LOGGING CONFIG
# ===========================

# Log level (error, warn, info, debug)
# LOG_LEVEL=info
